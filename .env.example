# Копируй в .env и заполняй — .env никогда не коммитится в git

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=oee_db
POSTGRES_USER=oee_user
POSTGRES_PASSWORD=changeme

# Собирается автоматически из полей выше (используется в SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://oee_user:changeme@postgres:5432/oee_db

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Auth ---
# Генерируй своё: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_me_with_random_64_char_hex
ACCESS_TOKEN_EXPIRE_MINUTES=480   # 8 часов = одна смена

# --- Приложение ---
APP_ENV=development               # development | production
DEBUG=true
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
